<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base Colors -->
    <Color x:Key="Color.Background">#FF0F0E1A</Color>
    <Color x:Key="Color.Foreground">#FFEAEAEA</Color>
    <Color x:Key="Color.Surface">#FF1A1929</Color>
    <Color x:Key="Color.Border">#FF3A3A4A</Color>
    <Color x:Key="Color.Accent">#FF7AB4FF</Color>
    <Color x:Key="Color.Error">#FFCF6679</Color>
    <Color x:Key="Color.Success">#FF7EB57E</Color>
    <Color x:Key="Color.TileBackground">#FF2A2935</Color>
    <Color x:Key="Color.TitleBackground">#FF222222</Color>

    <!-- Secondary Text Color -->
    <Color x:Key="Color.SecondaryText">#FF7A7A8A</Color>
    <Color x:Key="Color.Gold">#FFFFD700</Color>

    <!-- Inventory Rarity Colors -->
    <Color x:Key="Color.Rarity.Common">#FFA0A0A0</Color>
    <Color x:Key="Color.Rarity.Uncommon">#FF1EFF00</Color>
    <Color x:Key="Color.Rarity.Rare">#FF0070DD</Color>
    <Color x:Key="Color.Rarity.Epic">#FFA335EE</Color>
    <Color x:Key="Color.Rarity.Legendary">#FFFF8000</Color>
    <Color x:Key="Color.Rarity.Mythic">#FFFF0000</Color>

    <!-- Equipment Slot Colors -->
    <Color x:Key="Color.Equipment.Weapon">#FFFFB700</Color>
    <Color x:Key="Color.Equipment.Armor">#FF1EFF00</Color>
    <Color x:Key="Color.Equipment.Accessory">#FF0070DD</Color>

    <!-- Brushes - Base -->
    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Background}"/>
    <SolidColorBrush x:Key="Brush.Foreground" Color="{StaticResource Color.Foreground}"/>
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}"/>
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}"/>
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}"/>
    <SolidColorBrush x:Key="Brush.Error" Color="{StaticResource Color.Error}"/>
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}"/>
    <SolidColorBrush x:Key="Brush.TileBackground" Color="{StaticResource Color.TileBackground}"/>
    <SolidColorBrush x:Key="Brush.TitleBackground" Color="{StaticResource Color.TitleBackground}"/>

    <!-- Brushes - Secondary -->
    <SolidColorBrush x:Key="Brush.SecondaryText" Color="{StaticResource Color.SecondaryText}"/>
    <SolidColorBrush x:Key="Brush.Gold" Color="{StaticResource Color.Gold}"/>

    <!-- Brushes - Rarity -->
    <SolidColorBrush x:Key="Brush.Rarity.Common" Color="{StaticResource Color.Rarity.Common}"/>
    <SolidColorBrush x:Key="Brush.Rarity.Uncommon" Color="{StaticResource Color.Rarity.Uncommon}"/>
    <SolidColorBrush x:Key="Brush.Rarity.Rare" Color="{StaticResource Color.Rarity.Rare}"/>
    <SolidColorBrush x:Key="Brush.Rarity.Epic" Color="{StaticResource Color.Rarity.Epic}"/>
    <SolidColorBrush x:Key="Brush.Rarity.Legendary" Color="{StaticResource Color.Rarity.Legendary}"/>
    <SolidColorBrush x:Key="Brush.Rarity.Mythic" Color="{StaticResource Color.Rarity.Mythic}"/>

    <!-- Brushes - Equipment -->
    <SolidColorBrush x:Key="Brush.Equipment.Weapon" Color="{StaticResource Color.Equipment.Weapon}"/>
    <SolidColorBrush x:Key="Brush.Equipment.Armor" Color="{StaticResource Color.Equipment.Armor}"/>
    <SolidColorBrush x:Key="Brush.Equipment.Accessory" Color="{StaticResource Color.Equipment.Accessory}"/>

</ResourceDictionary>
