                    <Path Data="M120 290 C170 260, 230 270, 300 300 C350 322, 390 310, 420 292"
                          Stroke="#1Ab9a6ff" StrokeThickness="16" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    <Path Data="M110 340 C170 320, 240 330, 292 352 C330 368, 360 368, 392 356"
                          Stroke="#1A7a5cff" StrokeThickness="14" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>

                    <Ellipse Width="11" Height="11" Margin="242.5,206.5,0,0" Fill="#ffffff" Opacity="0.35" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <Ellipse Width="8" Height="8" Margin="304,234,0,0" Fill="#ffffff" Opacity="0.28" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <Ellipse Width="7.6" Height="7.6" Margin="214.2,288.2,0,0" Fill="#ffffff" Opacity="0.22" HorizontalAlignment="Left" VerticalAlignment="Top"/>
