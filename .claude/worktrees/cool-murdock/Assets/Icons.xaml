            <Grid Width="512" Height="512">
                <Grid.Resources>
                    <LinearGradientBrush x:Key="wood" StartPoint="0.35,0.92" EndPoint="0.64,0.16">
                        <GradientStop Offset="0" Color="#7a3f22"/>
                        <GradientStop Offset="0.55" Color="#b16739"/>
                        <GradientStop Offset="1" Color="#e0a063"/>
                    </LinearGradientBrush>
                    <LinearGradientBrush x:Key="woodHi" StartPoint="0.41,0.84" EndPoint="0.59,0.23">
                        <GradientStop Offset="0" Color="#00ffffff"/>
                        <GradientStop Offset="0.4" Color="#2effffff"/>
                        <GradientStop Offset="1" Color="#00ffffff"/>
                    </LinearGradientBrush>
                    <LinearGradientBrush x:Key="metal" StartPoint="0.18,0.23" EndPoint="0.82,0.51">
                        <GradientStop Offset="0" Color="#eef3f8"/>
                        <GradientStop Offset="0.45" Color="#a3afbc"/>
                        <GradientStop Offset="1" Color="#5b6775"/>
