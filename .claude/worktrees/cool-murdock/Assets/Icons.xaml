<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Default Icon -->
    <DataTemplate x:Key="Icon.Default">
        <Viewbox>
            <Grid Width="512" Height="512">
                <Grid.Resources>
                    <LinearGradientBrush x:Key="frameGrad" StartPoint="0.2,0.2" EndPoint="0.8,0.8">
                        <GradientStop Offset="0" Color="#3a3f4a"/>
                        <GradientStop Offset="1" Color="#161a22"/>
                    </LinearGradientBrush>
                    <RadialGradientBrush x:Key="bgGrad" Center="0.5,0.45" GradientOrigin="0.5,0.45" RadiusX="0.65" RadiusY="0.65">
                        <GradientStop Offset="0" Color="#2c3140"/>
                        <GradientStop Offset="1" Color="#11141b"/>
                    </RadialGradientBrush>
                    <LinearGradientBrush x:Key="crystalGrad" StartPoint="0.4,0.27" EndPoint="0.62,0.7">
                        <GradientStop Offset="0" Color="#cfd6e6"/>
                        <GradientStop Offset="0.5" Color="#7f8aa3"/>
                        <GradientStop Offset="1" Color="#3e4658"/>
                    </LinearGradientBrush>
                </Grid.Resources>

                <!-- Outer Frame -->
                <Rectangle Canvas.Left="56" Canvas.Top="56" Width="400" Height="400" RadiusX="64" RadiusY="64"
                           Fill="{StaticResource frameGrad}" Stroke="#0a0d12" StrokeThickness="14"/>

                <!-- Inner Panel -->
                <Rectangle Canvas.Left="96" Canvas.Top="96" Width="320" Height="320" RadiusX="40" RadiusY="40"
                           Fill="{StaticResource bgGrad}" Stroke="#0f1218" StrokeThickness="8"/>

                <!-- Subtle glow ring -->
                <Ellipse Width="220" Height="220" Stroke="#ffffff" StrokeThickness="16" Opacity="0.06"/>

                <!-- Generic Item Crystal -->
                <Grid>
                    <Path Data="M256 148 L330 210 L306 336 L256 380 L206 336 L182 210 Z"
                          Fill="{StaticResource crystalGrad}" Stroke="#0c0f14" StrokeThickness="10" StrokeLineJoin="Round">
                        <Path.Effect>
                            <DropShadowEffect ShadowDepth="10" BlurRadius="10" Opacity="0.35" Direction="270"/>
                        </Path.Effect>
                    </Path>

                    <!-- Facets -->
                    <Path Data="M256 148 L232 230 L182 210 Z" Fill="#ffffff" Opacity="0.18"/>
                    <Path Data="M256 148 L330 210 L280 230 Z" Fill="#000000" Opacity="0.18"/>
                    <Path Data="M206 336 L256 380 L306 336 Z" Fill="#000000" Opacity="0.15"/>

                    <!-- Highlight -->
                    <Path Data="M230 220 C250 200, 280 200, 300 220" Stroke="#ffffff" StrokeThickness="10" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.25"/>
                </Grid>
            </Grid>
        </Viewbox>
    </DataTemplate>

