                <Path Data="M168 386 L210 304 L314 318 L284 418 Z" Fill="#4a4e59" Opacity="0.85"/>
                <Path Data="M112 276 L210 304 L168 386 Z" Fill="#3a3e48" Opacity="0.9"/>

