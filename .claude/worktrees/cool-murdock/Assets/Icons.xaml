                    <LinearGradientBrush x:Key="cloak" StartPoint="0.29,0.23" EndPoint="0.74,0.9">
                        <GradientStop Offset="0" Color="#7b5cff"/>
                        <GradientStop Offset="0.55" Color="#3a2b8f"/>
                        <GradientStop Offset="1" Color="#140f3d"/>
                    </LinearGradientBrush>
                    <LinearGradientBrush x:Key="lining" StartPoint="0.33,0.31" EndPoint="0.64,0.84">
                        <GradientStop Offset="0" Color="#a58cff"/>
                        <GradientStop Offset="1" Color="#2b1f6a"/>
                    </LinearGradientBrush>
                </Grid.Resources>

                <Path Data="M168 178 C168 126,212 86,256 86 C300 86,344 126,344 178 C344 206,334 228,322 246 C356 284,392 352,396 430 C398 468,368 488,330 492 C292 496,274 478,256 478 C238 478,220 496,182 492 C144 488,114 468,116 430 C120 352,156 284,190 246 C178 228,168 206,168 178 Z"
                      Fill="{StaticResource cloak}" Stroke="#0a0b10" StrokeThickness="10"/>

                <Path Data="M206 190 C206 150,230 124,256 124 C282 124,306 150,306 190 C306 214,296 236,284 250 C272 264,266 272,256 272 C246 272,240 264,228 250 C216 236,206 214,206 190 Z"
                      Fill="{StaticResource lining}" Stroke="#0a0b10" StrokeThickness="8"/>
