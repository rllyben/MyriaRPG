                    <RadialGradientBrush x:Key="core" Center="0.42,0.36" GradientOrigin="0.42,0.36" RadiusX="0.7" RadiusY="0.7">
                        <GradientStop Offset="0" Color="#2b2d3a"/>
                        <GradientStop Offset="0.45" Color="#141523"/>
                        <GradientStop Offset="1" Color="#070711"/>
