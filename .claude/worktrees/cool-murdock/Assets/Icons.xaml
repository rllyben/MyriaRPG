                        <GradientStop Offset="0.6" Color="#7d2f1a"/>
                        <GradientStop Offset="1" Color="#541c10"/>
                    </LinearGradientBrush>
                </Grid.Resources>

                <Ellipse Width="340" Height="76" Margin="98,411,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Fill="#000" Opacity="0.12"/>

                <Path Data="M138 176 L220 110 L334 126 L404 214 L386 340 L284 418 L168 386 L112 276 Z"
