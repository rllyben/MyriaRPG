                <Ellipse Width="300" Height="56" Margin="106,434,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Fill="#000" Opacity="0.12"/>

                <Grid RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
