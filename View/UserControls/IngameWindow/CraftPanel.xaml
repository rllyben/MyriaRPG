<UserControl x:Class="MyriaRPG.View.Pages.Game.IngameWindow.NpcInteraction.CraftPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Brush.Background}">
    <Grid>
        <StackPanel Margin="20" Orientation="Vertical">
            <!-- Header -->
            <TextBlock Text="{Binding Title}" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="{DynamicResource Brush.Foreground}"
                       Margin="0,0,0,20"/>

            <!-- Recipes -->
            <Border Background="{DynamicResource Brush.TileBackground}" 
                    BorderBrush="{DynamicResource Brush.Border}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="15"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Recipes" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource Brush.SecondaryText}"
                               Margin="0,0,0,12"/>
                    
                    <ListBox ItemsSource="{Binding Recipes}"
                             SelectedItem="{Binding SelectedRecipe}"
                             Background="{DynamicResource Brush.Background}"
                             BorderThickness="0"
                             Height="120">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Brush.TileBackground}" 
                                        BorderBrush="{DynamicResource Brush.Border}" 
                                        BorderThickness="1"
                                        Padding="10"
                                        Margin="0,5,0,0"
                                        CornerRadius="4">
                                    <TextBlock Text="{Binding Name}" 
                                               FontSize="12" 
                                               FontWeight="Bold" 
                                               Foreground="{DynamicResource Brush.Foreground}"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Ingredients -->
            <Border Background="{DynamicResource Brush.TileBackground}" 
                    BorderBrush="{DynamicResource Brush.Border}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="15"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="{Binding IngredientsLabel}" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource Brush.SecondaryText}"
                               Margin="0,0,0,12"/>
                    
                    <ItemsControl ItemsSource="{Binding SelectedIngredients}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Brush.Background}" 
                                        BorderBrush="{DynamicResource Brush.Border}" 
                                        BorderThickness="1"
                                        Padding="10"
                                        Margin="0,5,0,0"
                                        CornerRadius="4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayString}" 
                                                   FontSize="11" 
                                                   Foreground="{DynamicResource Brush.SecondaryText}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Quantity Control -->
            <Border Background="{DynamicResource Brush.TileBackground}" 
                    BorderBrush="{DynamicResource Brush.Border}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="15"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="{Binding QuantityLabel}" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource Brush.SecondaryText}"
                               Margin="0,0,0,8"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="-" 
                                Command="{Binding DecreaseQuantityCommand}"
                                Width="40"
                                Padding="5"/>
                        
                        <TextBlock Text="{Binding Quantity}" 
                                   FontSize="14" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource Brush.Foreground}"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   Width="60"
                                   Margin="5,0,5,0"/>
                        
                        <Button Content="+" 
                                Command="{Binding IncreaseQuantityCommand}"
                                Width="40"
                                Padding="5"
                                Margin="0,0,10,0"/>
                        
                        <Button Content="{Binding MaxLabel}" 
                                Command="{Binding MaxQuantityCommand}"
                                Padding="10,5"/>
                    </StackPanel>

                    <TextBlock Text="{Binding MaxCraftable, StringFormat='Max: {0}'}" 
                               FontSize="11" 
                               Foreground="{DynamicResource Brush.SecondaryText}"/>
                </StackPanel>
            </Border>

            <!-- Status Message -->
            <Border Background="{DynamicResource Brush.TileBackground}" 
                    BorderBrush="{DynamicResource Brush.Border}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="15"
                    Margin="0,0,0,20">
                <TextBlock Text="{Binding StatusMessage}" 
                           FontSize="12" 
                           Foreground="{DynamicResource Brush.SecondaryText}"
                           TextWrapping="Wrap"
                           MinHeight="40"/>
            </Border>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                <Button Content="{Binding BtnBack}" 
                        Command="{Binding BackCommand}"
                        Style="{DynamicResource ButtonStyle}"
                        Padding="15,10"
                        Margin="0,0,10,0"/>
                
                <Button Content="{Binding BtnCraft}" 
                        Command="{Binding CraftCommand}"
                        IsEnabled="{Binding CanCraft}"
                        Style="{DynamicResource ButtonStyle}"
                        Padding="15,10"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
