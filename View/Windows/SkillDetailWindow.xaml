<Window x:Class="MyriaRPG.View.Windows.SkillDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyriaRPG.View.Windows"
        mc:Ignorable="d"
        Title="Skill Details"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Brush.Background}"
        ResizeMode="NoResize">
    <Border Padding="12" Background="{DynamicResource Brush.Background}">
        <StackPanel>
            <TextBlock Text="{Binding Name}"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.Foreground}" Margin="0,0,0,4"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="{Binding ClassName}" Foreground="{DynamicResource Brush.SecondaryText}" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding TypeText}" Foreground="{DynamicResource Brush.Foreground}" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding TargetText}" Foreground="{DynamicResource Brush.Foreground}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="Mana: " Foreground="{DynamicResource Brush.SecondaryText}"/>
                <TextBlock Text="{Binding ManaCost}" Foreground="{DynamicResource Brush.Foreground}"/>
                <TextBlock Text="   •   " Foreground="{DynamicResource Brush.SecondaryText}"/>
                <TextBlock Text="{Binding TimingText}" Foreground="{DynamicResource Brush.SecondaryText}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Scaling: " Foreground="{DynamicResource Brush.SecondaryText}"/>
                <TextBlock Text="{Binding ScalingText}" Foreground="{DynamicResource Brush.Foreground}"/>
            </StackPanel>

            <TextBlock Text="Description" FontWeight="SemiBold" Foreground="{DynamicResource Brush.SecondaryText}" Margin="0,0,0,4"/>
            <ScrollViewer MaxHeight="200">
                <TextBlock Text="{Binding Description}"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource Brush.Foreground}"/>
            </ScrollViewer>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Close" Width="80" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
