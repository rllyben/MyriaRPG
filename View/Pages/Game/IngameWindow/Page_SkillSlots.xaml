<Page x:Class="MyriaRPG.View.Pages.Game.IngameWindow.Page_SkillSlots"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Skill Slots">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Margin="12" Background="{DynamicResource Brush.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding TblTitle}"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.Foreground}"/>
                <TextBlock Text="  •  " Foreground="{DynamicResource Brush.SecondaryText}" FontSize="14" Margin="4,0"/>
                <TextBlock Text="{Binding SlotCountText}"
                           FontSize="14" Foreground="{DynamicResource Brush.SecondaryText}"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="{Binding TblBack}"
                    Command="{Binding GoBackCommand}"
                    VerticalAlignment="Center"
                    Padding="12,4"/>
        </Grid>

        <!-- Two-column layout -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: all known skills grouped -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Brush.TileBackground}"
                    CornerRadius="8" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding TblAvailable}"
                               FontWeight="SemiBold" Margin="0,0,0,6"
                               Foreground="{DynamicResource Brush.Foreground}"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Regular skills -->
                            <TextBlock Text="{Binding TblRegular}"
                                       FontSize="12" Opacity="0.7" Margin="0,4,0,2"
                                       Foreground="{DynamicResource Brush.Foreground}"/>
                            <ItemsControl ItemsSource="{Binding AvailableRegularSkills}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,2" Padding="6"
                                                Background="{DynamicResource Brush.Surface}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="1" CornerRadius="5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                                               Foreground="{DynamicResource Brush.Foreground}"/>
                                                    <TextBlock Text="{Binding TypeAndTarget}" FontSize="11" Opacity="0.7"
                                                               Foreground="{DynamicResource Brush.Foreground}"/>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="{Binding DataContext.TblSlot, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        Command="{Binding DataContext.SlotSkillCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding CanSlot}"
                                                        Padding="8,2" FontSize="11"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Combined skills -->
                            <TextBlock Text="{Binding TblCombined}"
                                       FontSize="12" Opacity="0.7" Margin="0,8,0,2"
                                       Foreground="{DynamicResource Brush.Foreground}"
                                       Visibility="{Binding HasCombinedSkills, Converter={StaticResource BoolToVis}}"/>
                            <ItemsControl ItemsSource="{Binding AvailableCombinedSkills}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,2" Padding="6"
                                                Background="{DynamicResource Brush.Surface}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="1" CornerRadius="5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                                               Foreground="{DynamicResource Brush.Foreground}"/>
                                                    <TextBlock Text="{Binding TypeAndTarget}" FontSize="11" Opacity="0.7"
                                                               Foreground="{DynamicResource Brush.Foreground}"/>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="{Binding DataContext.TblSlot, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        Command="{Binding DataContext.SlotSkillCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding CanSlot}"
                                                        Padding="8,2" FontSize="11"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Fusion skills -->
                            <TextBlock Text="{Binding TblFusion}"
                                       FontSize="12" Opacity="0.7" Margin="0,8,0,2"
                                       Foreground="{DynamicResource Brush.Foreground}"
                                       Visibility="{Binding HasFusionSkills, Converter={StaticResource BoolToVis}}"/>
                            <ItemsControl ItemsSource="{Binding AvailableFusionSkills}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,2" Padding="6"
                                                Background="{DynamicResource Brush.Surface}"
                                                BorderBrush="{DynamicResource Brush.Border}"
                                                BorderThickness="1" CornerRadius="5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12"
                                                               Foreground="{DynamicResource Brush.Foreground}"/>
                                                    <TextBlock Text="{Binding TypeAndTarget}" FontSize="11" Opacity="0.7"
                                                               Foreground="{DynamicResource Brush.Foreground}"/>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="{Binding DataContext.TblSlot, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        Command="{Binding DataContext.SlotSkillCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding CanSlot}"
                                                        Padding="8,2" FontSize="11"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- RIGHT: active slots -->
            <Border Grid.Column="2"
                    Background="{DynamicResource Brush.TileBackground}"
                    CornerRadius="8" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding TblActiveSlots}"
                               FontWeight="SemiBold" Margin="0,0,0,6"
                               Foreground="{DynamicResource Brush.Foreground}"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ActiveSlots}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,3" Padding="8"
                                            Background="{DynamicResource Brush.Surface}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="1" CornerRadius="5"
                                            MinHeight="44">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Slot number -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding SlotNumber}"
                                                       VerticalAlignment="Center"
                                                       Opacity="0.6" FontSize="12"
                                                       Foreground="{DynamicResource Brush.Foreground}"/>

                                            <!-- Skill name + tag -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SkillName}"
                                                           FontWeight="SemiBold" FontSize="13"
                                                           Foreground="{DynamicResource Brush.Foreground}"/>
                                                <TextBlock Text="{Binding SourceTag}"
                                                           FontSize="11" Opacity="0.65"
                                                           Foreground="{DynamicResource Brush.Foreground}"
                                                           Visibility="{Binding HasSourceTag, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>

                                            <!-- Move up/down -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="4,0">
                                                <Button Content="↑"
                                                        Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="4,2" FontSize="11" Margin="0,0,2,0"/>
                                                <Button Content="↓"
                                                        Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="4,2" FontSize="11"/>
                                            </StackPanel>

                                            <!-- Remove -->
                                            <Button Grid.Column="3"
                                                    Content="{Binding DataContext.TblUnslot, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    Command="{Binding DataContext.UnslotSkillCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="8,2" FontSize="11"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
