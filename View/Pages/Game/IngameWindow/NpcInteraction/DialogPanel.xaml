<Page x:Class="MyriaRPG.View.Pages.Game.IngameWindow.NpcInteraction.DialogPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MyriaRPG.View.Pages.Game.IngameWindow.NpcInteraction"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DialogPanel">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Dialog text -->
        <Border Padding="12"
                    CornerRadius="12"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1">
            <TextBlock Text="{Binding DialogText}"
                               Foreground="{DynamicResource Brush.Foreground}"
                           TextWrapping="Wrap"
                           FontSize="14"/>
        </Border>

        <!-- Service buttons -->
        <ItemsControl Grid.Row="1"
                          Margin="0,12,0,0"
                          ItemsSource="{Binding ServiceOptions}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"
                                   HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Command="{Binding Command}"
                                Padding="12,8"
                                Margin="6"
                                MinWidth="160">
                        <StackPanel>
                            <TextBlock Text="{Binding Text}" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Foreground}"/>
                            <TextBlock Text="{Binding Description}"
                               Foreground="{DynamicResource Brush.Foreground}"
                                           Opacity="0.75"
                                           TextWrapping="Wrap"
                                           FontSize="12"/>
                        </StackPanel>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Page>
