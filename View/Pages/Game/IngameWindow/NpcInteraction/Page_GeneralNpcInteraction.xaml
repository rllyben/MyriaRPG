<Page x:Class="MyriaRPG.View.Pages.Game.IngameWindow.NpcInteraction.Page_GeneralNpcInteraction"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:MyriaRPG.ViewModel.Pages.Game.IngameWindow.NpcInteraction"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MyriaRPG.View.Pages.Game.IngameWindow.NpcInteraction"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page_GeneralNpcInteraction">
    <Page.Resources>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Small inventory cell for shop panel -->
        <Style x:Key="ShopInventoryCell" TargetType="Border">
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderBrush" Value="#33000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Dialog Panel -->
        <DataTemplate DataType="{x:Type vm:DialogPanelViewModel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Dialog text -->
                <Border Padding="12"
                    CornerRadius="12"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1">
                    <TextBlock Text="{Binding DialogText}"
                               Foreground="{DynamicResource Brush.Foreground}"
                           TextWrapping="Wrap"
                           FontSize="14"/>
                </Border>

                <!-- Service buttons -->
                <ItemsControl Grid.Row="1"
                          Margin="0,12,0,0"
                          ItemsSource="{Binding ServiceOptions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"
                                   HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding Command}"
                                Padding="12,8"
                                Margin="6"
                                MinWidth="160">
                                <StackPanel>
                                    <TextBlock Text="{Binding Text}" FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Foreground}"/>
                                    <TextBlock Text="{Binding Description}"
                               Foreground="{DynamicResource Brush.Foreground}"
                                           Opacity="0.75"
                                           TextWrapping="Wrap"
                                           FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </DataTemplate>


        <!-- Shop Panel -->
        <DataTemplate DataType="{x:Type vm:ShopPanelViewModel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Shop header row -->
                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="{Binding Title}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.Foreground}"
                           DockPanel.Dock="Left"/>

                    <TextBlock Text="{Binding MoneyText}"
                           DockPanel.Dock="Right"
                           Foreground="{DynamicResource Brush.Foreground}"
                           Opacity="0.85"/>
                </DockPanel>

                <!-- Body: 3 columns -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Column 0: Stock list -->
                    <Border Grid.Column="0"
                        Padding="8"
                        CornerRadius="12"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1">

                        <DockPanel>
                            <TextBlock Text="{Binding StockHeader}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Foreground}"
                                   Margin="2,0,0,6"
                                   DockPanel.Dock="Top"/>

                            <ListBox ItemsSource="{Binding Stock}"
                                 SelectedItem="{Binding SelectedStock}"
                                 BorderThickness="0"
                                 Background="{x:Null}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{DynamicResource Brush.Foreground}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!-- Column 2: Item details -->
                    <Border Grid.Column="2"
                        Padding="10"
                        CornerRadius="12"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Item name -->
                            <TextBlock Text="{Binding SelectedName}"
                                   FontSize="16"
                                   Foreground="{DynamicResource Brush.Foreground}"
                                   FontWeight="SemiBold"/>

                            <!-- Item description -->
                            <TextBlock Grid.Row="1"
                                   Text="{Binding SelectedDescription}"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource Brush.Foreground}"
                                   Opacity="0.8"
                                   TextWrapping="Wrap"/>

                            <!-- Price info -->
                            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                <TextBlock Text="{Binding SelectedTypeText}"
                                       Foreground="{DynamicResource Brush.Foreground}"
                                       Opacity="0.7"
                                       Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedPriceText}"
                                       Foreground="{DynamicResource Brush.Foreground}"
                                       FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SelectedSellValueText}"
                                       Foreground="{DynamicResource Brush.Foreground}"
                                       Opacity="0.7"
                                       Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Buy button -->
                            <Button Grid.Row="4"
                                Content="{Binding BtnBuy}"
                                Command="{Binding BuyCommand}"
                                IsEnabled="{Binding CanBuy}"
                                HorizontalAlignment="Right"
                                Margin="0,10,0,0"/>
                        </Grid>
                    </Border>

                    <!-- Column 4: Player inventory (sell by right-click) -->
                    <Border Grid.Column="4"
                        Padding="8"
                        CornerRadius="12"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1">

                        <DockPanel>
                            <TextBlock Text="{Binding InventoryHeader}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.Foreground}"
                                   Margin="2,0,0,6"
                                   DockPanel.Dock="Top"/>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding PlayerInventory}" Background="{x:Null}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="5" HorizontalAlignment="Left"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource ShopInventoryCell}"
                                                    BorderBrush="{Binding Color}"
                                                    BorderThickness="2">
                                                <Grid>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="9"
                                                               TextTrimming="CharacterEllipsis"
                                                               Foreground="{DynamicResource Brush.Foreground}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                    <!-- Quantity overlay -->
                                                    <TextBlock Text="{Binding Quantity}"
                                                               FontSize="9" FontWeight="Bold"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Bottom"
                                                               Margin="0,0,2,1"
                                                               Foreground="{DynamicResource Brush.Foreground}"
                                                               Visibility="{Binding ShowQuantityVisibility}"/>
                                                </Grid>
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="RightClick"
                                                        Command="{Binding DataContext.SellItemCommand,
                                                            RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type ItemsControl}}}"
                                                        CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <Border.ToolTip>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding Type}"/>
                                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" MaxWidth="280"/>
                                                        <TextBlock Text="{Binding Rarity}" FontStyle="Italic"/>
                                                    </StackPanel>
                                                </Border.ToolTip>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- Sell confirmation overlay -->
                <Border Grid.Row="0" Grid.RowSpan="3"
                        Visibility="{Binding ShowConfirmDialog, Converter={StaticResource BoolToVis}}"
                        Background="#CC000000" CornerRadius="12" Panel.ZIndex="10">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ConfirmMessage}"
                                   Foreground="White" FontSize="14" TextWrapping="Wrap"
                                   Margin="20" TextAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="{Binding BtnYes}"
                                    Command="{Binding ConfirmSellCommand}"
                                    Margin="0,0,12,0" MinWidth="80" Padding="8,4"/>
                            <Button Content="{Binding BtnNo}"
                                    Command="{Binding CancelSellCommand}"
                                    MinWidth="80" Padding="8,4"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Back -->
                <Button Grid.Row="2"
                    Content="{Binding BtnBack}"
                    Command="{Binding BackCommand}"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0"/>
            </Grid>
        </DataTemplate>


        <!-- Upgrade Panel -->
        <DataTemplate DataType="{x:Type vm:UpgradePanelViewModel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{Binding Title}"
                       FontSize="16"
                       Foreground="{DynamicResource Brush.Foreground}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Equipment list -->
                    <Border Grid.Column="0"
                        Padding="8"
                        CornerRadius="12"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1">

                        <ListBox ItemsSource="{Binding Equipment}"
                             SelectedItem="{Binding SelectedEquipment}"
                             BorderThickness="0"
                             Background="{x:Null}"
                             Foreground="{DynamicResource Brush.Foreground}"/>
                    </Border>

                    <!-- Selected details -->
                    <Border Grid.Column="2"
                        Padding="10"
                        CornerRadius="12"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1">

                        <StackPanel>
                            <TextBlock Text="{Binding SelectedName}" Foreground="{DynamicResource Brush.Foreground}" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedUpgradeText}" Foreground="{DynamicResource Brush.Foreground}" Margin="0,6,0,0" Opacity="0.85"/>
                            <TextBlock Text="{Binding UpgradeCostText}" Foreground="{DynamicResource Brush.Foreground}" Margin="0,6,0,10" Opacity="0.85"/>

                            <Button Content="{Binding BtnUpgrade}"
                                Command="{Binding UpgradeCommand}"
                                IsEnabled="{Binding CanUpgrade}"
                                HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Button Grid.Row="2"
                    Content="{Binding BtnBack}"
                    Command="{Binding BackCommand}"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0"/>
            </Grid>
        </DataTemplate>


        <!-- Craft Panel -->
        <DataTemplate DataType="{x:Type vm:CraftPanelViewModel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{Binding Title}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.Foreground}"
                       Margin="0,0,0,10"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Recipes -->
                    <Border Grid.Column="0"
                        Padding="8"
                        CornerRadius="12"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1">

                        <ListBox ItemsSource="{Binding Recipes}"
                             SelectedItem="{Binding SelectedRecipe}"
                             BorderThickness="0"
                             Foreground="{DynamicResource Brush.Foreground}"
                             Background="{x:Null}"/>
                    </Border>

                    <!-- Recipe details -->
                    <Border Grid.Column="2"
                        Padding="10"
                        CornerRadius="12"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header: Icon + Name -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <!-- Upgrade Stone Icon (SVG Path) -->
                                <ContentControl ContentTemplate="{StaticResource Icon.upgrade_stone}" 
                                                Visibility="{Binding SelectedRecipe.Id, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter='upgrade_stone'}"
                                                Width="{Binding FontSize, ElementName=RecipeNameText}"
                                                Height="{Binding FontSize, ElementName=RecipeNameText}"/>
                                
                                <TextBlock x:Name="RecipeNameText"
                                           Text="{Binding SelectedName}" 
                                           FontSize="20"
                                           Foreground="{DynamicResource Brush.Foreground}" 
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"/>
                            </StackPanel>

                            <!-- Ingredients List -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding SelectedIngredients}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,4" Padding="8" Background="{DynamicResource Brush.Background}" CornerRadius="4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Iron Ore Icon (SVG Path) -->
                                                    <ContentControl ContentTemplate="{StaticResource Icon.iron_ore}" 
                                                                    Visibility="{Binding Id, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter='iron_ore'}"
                                                                    Width="{Binding FontSize, ElementName=IngredientNameText}"
                                                                    Height="{Binding FontSize, ElementName=IngredientNameText}"/>

                                                    <TextBlock x:Name="IngredientNameText"
                                                               Grid.Column="1"
                                                               Text="{Binding DisplayString}"
                                                               Foreground="{DynamicResource Brush.Foreground}"
                                                               VerticalAlignment="Center"
                                                               Margin="10,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Footer: Quantity + Craft Button -->
                            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="{Binding QuantityLabel}" 
                                               Foreground="{DynamicResource Brush.Foreground}" 
                                               VerticalAlignment="Center"/>
                                    
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                        <Button Content="-" Command="{Binding DecreaseQuantityCommand}" Width="30" Height="30"/>
                                        <TextBox Text="{Binding Quantity}" 
                                                 Width="50" 
                                                 TextAlignment="Center" 
                                                 VerticalContentAlignment="Center"
                                                 Margin="5,0"/>
                                        <Button Content="+" Command="{Binding IncreaseQuantityCommand}" Width="30" Height="30"/>
                                        <Button Content="{Binding MaxLabel}" Command="{Binding MaxQuantityCommand}" Margin="5,0,0,0" Padding="5,0"/>
                                    </StackPanel>
                                </DockPanel>

                                <Button Content="{Binding BtnCraft}"
                                        Command="{Binding CraftCommand}"
                                        IsEnabled="{Binding CanCraft}"
                                        Height="40"
                                        FontSize="16"
                                        FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Button Grid.Row="2"
                    Content="{Binding BtnBack}"
                    Command="{Binding BackCommand}"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0"/>
            </Grid>
        </DataTemplate>

    </Page.Resources>
    
    <ContentControl Content="{Binding CurrentPanel}"/>
</Page>
