<Page x:Class="MyriaRPG.View.Pages.Game.IngameWindow.NpcInteraction.CraftPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MyriaRPG.View.Pages.Game.IngameWindow.NpcInteraction"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CraftPanel">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Brush.Foreground}"
                       Margin="0,0,0,10"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Recipes -->
            <Border Grid.Column="0"
                        Padding="8"
                        CornerRadius="12"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1">

                <ListBox ItemsSource="{Binding Recipes}"
                             SelectedItem="{Binding SelectedRecipe}"
                             BorderThickness="0"
                             Foreground="{DynamicResource Brush.Foreground}"
                             Background="{x:Null}"/>
            </Border>

            <!-- Recipe details -->
            <Border Grid.Column="2"
                        Padding="10"
                        CornerRadius="12"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header: Icon + Name -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <!-- Upgrade Stone Icon (SVG Path) -->
                        <ContentControl ContentTemplate="{StaticResource Icon.upgrade_stone}" 
                                                Width="{Binding FontSize, ElementName=RecipeNameText}"
                                                Height="{Binding FontSize, ElementName=RecipeNameText}"/>

                        <TextBlock x:Name="RecipeNameText"
                                           Text="{Binding SelectedName}" 
                                           FontSize="20"
                                           Foreground="{DynamicResource Brush.Foreground}" 
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"/>
                    </StackPanel>

                    <!-- Ingredients List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SelectedIngredients}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,4" Padding="8" Background="{DynamicResource Brush.Background}" CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Iron Ore Icon (SVG Path) -->
                                            <ContentControl ContentTemplate="{StaticResource Icon.iron_ore}" 
                                                                    Width="{Binding FontSize, ElementName=IngredientNameText}"
                                                                    Height="{Binding FontSize, ElementName=IngredientNameText}"/>

                                            <TextBlock x:Name="IngredientNameText"
                                                               Grid.Column="1"
                                                               Text="{Binding DisplayString}"
                                                               Foreground="{DynamicResource Brush.Foreground}"
                                                               VerticalAlignment="Center"
                                                               Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Footer: Quantity + Craft Button -->
                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="{Binding QuantityLabel}" 
                                               Foreground="{DynamicResource Brush.Foreground}" 
                                               VerticalAlignment="Center"/>

                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                <Button Content="-" Command="{Binding DecreaseQuantityCommand}" Width="30" Height="30"/>
                                <TextBox Text="{Binding Quantity}" 
                                                 Width="50" 
                                                 TextAlignment="Center" 
                                                 VerticalContentAlignment="Center"
                                                 Margin="5,0"/>
                                <Button Content="+" Command="{Binding IncreaseQuantityCommand}" Width="30" Height="30"/>
                                <Button Content="{Binding MaxLabel}" Command="{Binding MaxQuantityCommand}" Margin="5,0,0,0" Padding="5,0"/>
                            </StackPanel>
                        </DockPanel>

                        <Button Content="{Binding BtnCraft}"
                                        Command="{Binding CraftCommand}"
                                        IsEnabled="{Binding CanCraft}"
                                        Height="40"
                                        FontSize="16"
                                        FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Button Grid.Row="2"
                    Content="{Binding BtnBack}"
                    Command="{Binding BackCommand}"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0"/>
    </Grid>
</Page>
