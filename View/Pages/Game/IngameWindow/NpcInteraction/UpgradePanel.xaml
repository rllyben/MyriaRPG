<UserControl x:Class="MyriaRPG.View.Pages.Game.IngameWindow.NpcInteraction.UpgradePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Brush.Background}">
    <Grid>
        <StackPanel Margin="20" Orientation="Vertical">
            <!-- Header -->
            <TextBlock Text="{Binding Title}" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="{DynamicResource Brush.Foreground}"
                       Margin="0,0,0,20"/>

            <!-- Equipment List -->
            <Border Background="{DynamicResource Brush.TileBackground}" 
                    BorderBrush="{DynamicResource Brush.Border}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="15"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Equipment" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource Brush.SecondaryText}"
                               Margin="0,0,0,12"/>
                    
                    <ListBox ItemsSource="{Binding Equipment}"
                             SelectedItem="{Binding SelectedEquipment}"
                             Background="{DynamicResource Brush.Background}"
                             BorderThickness="0"
                             Height="200">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Brush.TileBackground}" 
                                        BorderBrush="{DynamicResource Brush.Border}" 
                                        BorderThickness="1"
                                        Padding="10"
                                        Margin="0,5,0,0"
                                        CornerRadius="4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" 
                                                   FontSize="12" 
                                                   FontWeight="Bold" 
                                                   Foreground="{DynamicResource Brush.Foreground}"/>
                                        <TextBlock Text="{Binding UpgradeLevel, StringFormat='Level: +{0}'}" 
                                                   FontSize="11" 
                                                   Foreground="{DynamicResource Brush.SecondaryText}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Selected Item Details -->
            <Border Background="{DynamicResource Brush.TileBackground}" 
                    BorderBrush="{DynamicResource Brush.Border}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="15"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Details" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource Brush.SecondaryText}"
                               Margin="0,0,0,12"/>
                    
                    <TextBlock Text="{Binding SelectedName}" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource Brush.Foreground}"
                               Margin="0,0,0,8"/>
                    
                    <TextBlock Text="{Binding SelectedLevel}" 
                               FontSize="12" 
                               Foreground="{DynamicResource Brush.SecondaryText}"
                               Margin="0,0,0,8"/>
                    
                    <TextBlock Text="{Binding UpgradeCost}" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource Brush.Gold}"
                               Margin="0,0,0,8"/>
                </StackPanel>
            </Border>

            <!-- Status Message -->
            <Border Background="{DynamicResource Brush.TileBackground}" 
                    BorderBrush="{DynamicResource Brush.Border}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="15"
                    Margin="0,0,0,20">
                <TextBlock Text="{Binding StatusMessage}" 
                           FontSize="12" 
                           Foreground="{DynamicResource Brush.SecondaryText}"
                           TextWrapping="Wrap"
                           MinHeight="40"/>
            </Border>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,0">
                <Button Content="{Binding BtnBack}" 
                        Command="{Binding BackCommand}"
                        Style="{DynamicResource ButtonStyle}"
                        Padding="15,10"
                        Margin="0,0,10,0"/>
                
                <Button Content="{Binding BtnUpgrade}" 
                        Command="{Binding UpgradeCommand}"
                        IsEnabled="{Binding CanUpgrade}"
                        Style="{DynamicResource ButtonStyle}"
                        Padding="15,10"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
