<Page x:Class="MyriaRPG.View.Pages.Game.IngameWindow.NpcInteraction.UpgradePanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MyriaRPG.View.Pages.Game.IngameWindow.NpcInteraction"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="UpgradePanel">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title}"
                       FontSize="16"
                       Foreground="{DynamicResource Brush.Foreground}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Equipment list -->
            <Border Grid.Column="0"
                        Padding="8"
                        CornerRadius="12"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1">

                <ListBox ItemsSource="{Binding Equipment}"
                             SelectedItem="{Binding SelectedEquipment}"
                             BorderThickness="0"
                             Background="{x:Null}"
                             Foreground="{DynamicResource Brush.Foreground}"/>
            </Border>

            <!-- Selected details -->
            <Border Grid.Column="2"
                        Padding="10"
                        CornerRadius="12"
                        Background="{DynamicResource Brush.Surface}"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1">

                <StackPanel>
                    <TextBlock Text="{Binding SelectedName}" Foreground="{DynamicResource Brush.Foreground}" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedUpgradeText}" Foreground="{DynamicResource Brush.Foreground}" Margin="0,6,0,0" Opacity="0.85"/>
                    <TextBlock Text="{Binding UpgradeCostText}" Foreground="{DynamicResource Brush.Foreground}" Margin="0,6,0,10" Opacity="0.85"/>

                    <Button Content="{Binding BtnUpgrade}"
                                Command="{Binding UpgradeCommand}"
                                IsEnabled="{Binding CanUpgrade}"
                                HorizontalAlignment="Right"/>
                </StackPanel>
            </Border>
        </Grid>

        <Button Grid.Row="2"
                    Content="{Binding BtnBack}"
                    Command="{Binding BackCommand}"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0"/>
    </Grid>
</Page>
