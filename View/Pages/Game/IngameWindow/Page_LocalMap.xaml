<Page x:Class="MyriaRPG.View.Pages.Game.IngameWindow.Page_LocalMap"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:MyriaRPG.View.UserControls"
      mc:Ignorable="d"
      Title="Map">

    <Grid Background="{DynamicResource Brush.Background}" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: title left, zoom buttons right -->
        <Grid Grid.Row="0" Margin="4,0,0,10">
            <TextBlock Text="{Binding MapTitle}"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{DynamicResource Brush.Foreground}"
                       VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button x:Name="BtnZoomIn"
                        Content="＋"
                        Width="36" Height="36"
                        Padding="0"
                        FontSize="18"
                        Click="BtnZoomIn_Click"
                        ToolTip="Zoom in"/>
                <Button x:Name="BtnZoomOut"
                        Content="－"
                        Width="36" Height="36"
                        Padding="0"
                        FontSize="18"
                        Margin="6,0,0,0"
                        Click="BtnZoomOut_Click"
                        ToolTip="Zoom out"/>
            </StackPanel>
        </Grid>

        <!-- Map canvas -->
        <controls:LocalMapControl x:Name="MapControl"
                                   Grid.Row="1"
                                   Nodes="{Binding Nodes}"
                                   Edges="{Binding Edges}"/>
    </Grid>
</Page>
