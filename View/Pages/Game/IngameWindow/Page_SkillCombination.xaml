<Page x:Class="MyriaRPG.View.Pages.Game.IngameWindow.Page_SkillCombination"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="Skill Combination">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Margin="12" Background="{DynamicResource Brush.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding TblTitle}"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.Foreground}"/>
                <TextBlock Text="  •  " Foreground="{DynamicResource Brush.SecondaryText}" FontSize="14" Margin="4,0"/>
                <TextBlock Text="{Binding HeaderText}"
                           FontSize="14" Foreground="{DynamicResource Brush.SecondaryText}"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="{Binding TblBack}"
                    Command="{Binding GoBackCommand}"
                    VerticalAlignment="Center"
                    Padding="12,4"/>
        </Grid>

        <!-- Main three-column layout -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: available base skills -->
            <Border Grid.Column="0"
                    Background="{DynamicResource Brush.TileBackground}"
                    CornerRadius="8" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding TblAvailable}"
                               FontWeight="SemiBold" Margin="0,0,0,6"
                               Foreground="{DynamicResource Brush.Foreground}"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AvailableSkills}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,3" Padding="6"
                                            Background="{DynamicResource Brush.Surface}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="1" CornerRadius="5">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="{Binding Name}"
                                                       FontWeight="SemiBold" FontSize="13"
                                                       Foreground="{DynamicResource Brush.Foreground}"/>
                                            <TextBlock Grid.Row="1" Text="{Binding ShortDescription}"
                                                       FontSize="11" Opacity="0.75"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{DynamicResource Brush.Foreground}"/>
                                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                                                <Button Content="{Binding DataContext.TblAddToSlot, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        Command="{Binding DataContext.AddToInputCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="8,2" FontSize="11"
                                                        IsEnabled="{Binding DataContext.CanAddMore, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- CENTER: input slots + combine button -->
            <Border Grid.Column="2"
                    Background="{DynamicResource Brush.TileBackground}"
                    CornerRadius="8" Padding="12">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding TblInputSlots}"
                               FontWeight="SemiBold" Margin="0,0,0,8"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource Brush.Foreground}"/>

                    <!-- 5 input slots -->
                    <ItemsControl ItemsSource="{Binding InputSlots}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,4" Padding="8"
                                        Background="{DynamicResource Brush.Surface}"
                                        BorderBrush="{DynamicResource Brush.Border}"
                                        BorderThickness="1" CornerRadius="6"
                                        MinHeight="40">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Label}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Brush.Foreground}"/>
                                        <Button Grid.Column="1"
                                                Content="✕"
                                                Command="{Binding DataContext.RemoveInputCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Padding="6,2" FontSize="11"
                                                Visibility="{Binding IsSet, Converter={StaticResource BoolToVis}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="{Binding InputCountText}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,4"
                               FontSize="12" Opacity="0.75"
                               Foreground="{DynamicResource Brush.Foreground}"/>

                    <Button Content="{Binding TblCombine}"
                            Command="{Binding CombineCommand}"
                            IsEnabled="{Binding CanCombine}"
                            HorizontalAlignment="Center"
                            Padding="20,6" FontSize="14" FontWeight="SemiBold"
                            Margin="0,8,0,0"/>

                    <TextBlock Text="{Binding StatusText}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource Brush.Accent}"
                               Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Border>

            <!-- RIGHT: created combinations -->
            <Border Grid.Column="4"
                    Background="{DynamicResource Brush.TileBackground}"
                    CornerRadius="8" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding TblCreated}"
                               FontWeight="SemiBold" Margin="0,0,0,6"
                               Foreground="{DynamicResource Brush.Foreground}"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CombinedSkills}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,3" Padding="6"
                                            Background="{DynamicResource Brush.Surface}"
                                            BorderBrush="{DynamicResource Brush.Border}"
                                            BorderThickness="1" CornerRadius="5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontWeight="SemiBold" FontSize="13"
                                                       Foreground="{DynamicResource Brush.Foreground}"/>
                                            <TextBlock Text="{Binding ComponentsText}"
                                                       FontSize="11" Opacity="0.75"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource Brush.Foreground}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
