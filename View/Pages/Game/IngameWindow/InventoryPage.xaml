<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">
  <PropertyGroup>
    <UseWPF>true</UseWPF>
  </PropertyGroup>
</Project>

<Page x:Class="MyriaRPG.Pages.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:MyriaRPG.Pages"
      xmlns:vm="clr-namespace:MyriaRPG.ViewModels"
      Title="Inventory" Height="1080" Width="1920"
      Background="#0F0E1A">

    <Page.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- Rarity Color Definitions -->
        <SolidColorBrush x:Key="RarityCommon" Color="#A0A0A0"/>
        <SolidColorBrush x:Key="RarityUncommon" Color="#1EFF00"/>
        <SolidColorBrush x:Key="RarityRare" Color="#0070DD"/>
        <SolidColorBrush x:Key="RarityEpic" Color="#A335EE"/>
        <SolidColorBrush x:Key="RarityLegendary" Color="#FF8000"/>
        <SolidColorBrush x:Key="RarityMythic" Color="#FF0000"/>

        <!-- Equipment Slot Style -->
        <Style x:Key="EquipmentSlotStyle" TargetType="ContentControl">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="120"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Border Background="#1A1929" BorderBrush="#3A3A4A" BorderThickness="2" CornerRadius="8">
                            <Grid>
                                <TextBlock Text="{TemplateBinding Tag}" 
                                          Foreground="#7A7A8A" 
                                          FontSize="11" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          FontWeight="Bold"/>
                                <ContentPresenter/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Inventory Slot Style -->
        <Style x:Key="InventorySlotStyle" TargetType="Border">
            <Setter Property="Background" Value="#1A1929"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3A3A4A"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="AllowDrop" Value="True"/>
        </Style>

        <!-- Item Style with Rarity Border -->
        <Style x:Key="ItemContainerStyle" TargetType="Grid">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Page.Resources>

    <Grid>
        <!-- Background Pattern -->
        <Rectangle Fill="#0F0E1A"/>
        <Canvas Opacity="0.05">
            <Rectangle Fill="White" Width="1920" Height="1080" Canvas.Left="0" Canvas.Top="0"/>
        </Canvas>

        <StackPanel Orientation="Vertical" Margin="20">
            <!-- Header -->
            <TextBlock Text="INVENTORY" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="#E0E0E0"
                       Margin="0,0,0,20"
                       FontFamily="Segoe UI"/>

            <!-- Equipment Section -->
            <Border Background="#1A1929" BorderBrush="#3A3A4A" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="EQUIPMENT" FontSize="14" Foreground="#7A7A8A" FontWeight="Bold" Margin="0,0,0,12"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <!-- Weapon Slot -->
                        <ContentControl x:Name="WeaponSlot" 
                                       Style="{StaticResource EquipmentSlotStyle}"
                                       DataContext="{Binding WeaponSlot}"
                                       Tag="WEAPON"
                                       AllowDrop="True"
                                       Drop="EquipmentSlot_Drop"
                                       DragOver="EquipmentSlot_DragOver">
                            <Border BorderBrush="{Binding BorderColor}" BorderThickness="2" CornerRadius="4">
                                <Canvas x:Name="WeaponSlotCanvas" Background="Transparent"/>
                            </Border>
                        </ContentControl>

                        <!-- Armor Slot -->
                        <ContentControl x:Name="ArmorSlot" 
                                       Style="{StaticResource EquipmentSlotStyle}"
                                       DataContext="{Binding ArmorSlot}"
                                       Tag="ARMOR"
                                       AllowDrop="True"
                                       Drop="EquipmentSlot_Drop"
                                       DragOver="EquipmentSlot_DragOver">
                            <Border BorderBrush="{Binding BorderColor}" BorderThickness="2" CornerRadius="4">
                                <Canvas x:Name="ArmorSlotCanvas" Background="Transparent"/>
                            </Border>
                        </ContentControl>

                        <!-- Accessory Slot -->
                        <ContentControl x:Name="AccessorySlot" 
                                       Style="{StaticResource EquipmentSlotStyle}"
                                       DataContext="{Binding AccessorySlot}"
                                       Tag="ACCESSORY"
                                       AllowDrop="True"
                                       Drop="EquipmentSlot_Drop"
                                       DragOver="EquipmentSlot_DragOver">
                            <Border BorderBrush="{Binding BorderColor}" BorderThickness="2" CornerRadius="4">
                                <Canvas x:Name="AccessorySlotCanvas" Background="Transparent"/>
                            </Border>
                        </ContentControl>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Inventory Grid Section -->
            <Border Background="#1A1929" BorderBrush="#3A3A4A" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="BACKPACK" FontSize="14" Foreground="#7A7A8A" FontWeight="Bold" Margin="0,0,0,12"/>
                    
                    <Grid x:Name="InventoryGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Money Section -->
            <Border Background="#1A1929" BorderBrush="#3A3A4A" BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="💰" FontSize="24" Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="MONEY BAG" FontSize="12" Foreground="#7A7A8A" FontWeight="Bold"/>
                        <TextBlock Text="{Binding MoneyDisplay}" 
                                  FontSize="18" 
                                  Foreground="#FFD700" 
                                  FontWeight="Bold"
                                  FontFamily="Consolas"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Tooltip -->
        <Border x:Name="ItemTooltip" 
               Background="#2A2935" 
               BorderBrush="#3A3A4A" 
               BorderThickness="1" 
               CornerRadius="6"
               Padding="12"
               Visibility="{Binding IsTooltipVisible, Converter={StaticResource BoolToVisibilityConverter}}"
               MaxWidth="300">
            <StackPanel DataContext="{Binding CurrentTooltip}">
                <TextBlock Text="{Binding ItemName}" FontSize="14" FontWeight="Bold" Foreground="#E0E0E0" TextWrapping="Wrap" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding ItemType}" FontSize="11" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding ItemRarity}" FontSize="11" FontWeight="Bold" Foreground="{Binding RarityColor}" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding ItemStats}" FontSize="10" Foreground="#B0B0B0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
