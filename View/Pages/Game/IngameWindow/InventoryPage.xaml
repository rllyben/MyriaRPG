<Page x:Class="MyriaRPG.Pages.InventoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:MyriaRPG.Pages"
      Title="Inventory"
      Background="{DynamicResource Brush.Background}">

    <Page.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- Index to Column Converter -->
        <local:IndexToColumnConverter x:Key="IndexToColumnConverter"/>
        
        <!-- Index to Row Converter -->
        <local:IndexToRowConverter x:Key="IndexToRowConverter"/>
        
        <!-- Stack Size to Visibility Converter -->
        <local:StackSizeToVisibilityConverter x:Key="StackSizeToVisibilityConverter"/>

        <!-- Equipment Slot Style -->
        <Style x:Key="EquipmentSlotStyle" TargetType="ContentControl">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Border Background="{DynamicResource Brush.TileBackground}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="2" CornerRadius="8">
                            <Grid>
                                <TextBlock Text="{TemplateBinding Tag}" 
                                          Foreground="{DynamicResource Brush.SecondaryText}" 
                                          FontSize="11" 
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"
                                          FontWeight="Bold"/>
                                <ContentPresenter/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Inventory Slot Style -->
        <Style x:Key="InventorySlotStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.TileBackground}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="AllowDrop" Value="True"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>

        <!-- Icon Switcher Style - Dynamically selects icon based on Item.Id -->
        <Style x:Key="IconSwitcherStyle" TargetType="ContentControl">
            <Setter Property="ContentTemplate" Value="{StaticResource Icon.Default}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Content.Id, RelativeSource={RelativeSource Self}}" Value="iron_ore">
                    <Setter Property="ContentTemplate" Value="{StaticResource Icon.iron_ore}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Content.Id, RelativeSource={RelativeSource Self}}" Value="upgrade_stone">
                    <Setter Property="ContentTemplate" Value="{StaticResource Icon.upgrade_stone}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Content.Id, RelativeSource={RelativeSource Self}}" Value="pickaxe">
                    <Setter Property="ContentTemplate" Value="{StaticResource Icon.pickaxe}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Content.Id, RelativeSource={RelativeSource Self}}" Value="shadow_remnant">
                    <Setter Property="ContentTemplate" Value="{StaticResource Icon.shadow_remnant}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Content.Id, RelativeSource={RelativeSource Self}}" Value="mage_robe">
                    <Setter Property="ContentTemplate" Value="{StaticResource Icon.mage_robe}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </Page.Resources>

    <Grid>
        <!-- Background Pattern -->
        <Rectangle Fill="{DynamicResource Brush.Background}"/>
        <Canvas Opacity="0.05">
            <Rectangle Fill="White" Canvas.Left="0" Canvas.Top="0" Width="1920" Height="1080"/>
        </Canvas>

        <StackPanel Orientation="Vertical" Margin="20">
            <!-- Header -->
            <TextBlock Text="{Binding InventoryTitle}" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="{DynamicResource Brush.Foreground}"
                       Margin="0,0,0,20"
                       FontFamily="Segoe UI"/>

            <!-- Equipment Section -->
            <Border Background="{DynamicResource Brush.TileBackground}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="{Binding EquipmentTitle}" FontSize="14" Foreground="{DynamicResource Brush.SecondaryText}" FontWeight="Bold" Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <!-- Weapon Slot -->
                        <ContentControl x:Name="WeaponSlot" 
                                       Style="{StaticResource EquipmentSlotStyle}"
                                       DataContext="{Binding WeaponSlot}"
                                       Tag="{Binding WeaponHint}"
                                       AllowDrop="True"
                                       Drop="EquipmentSlot_Drop"
                                       DragOver="EquipmentSlot_DragOver"
                                       PreviewMouseLeftButtonDown="EquipmentSlot_PreviewMouseLeftButtonDown"
                                       MouseEnter="EquipmentSlot_MouseEnter"
                                       MouseLeave="EquipmentSlot_MouseLeave">
                            <Border BorderBrush="{Binding BorderColor}" BorderThickness="2" CornerRadius="4">
                                <!-- Icon from DataTemplate -->
                                <ContentControl Content="{Binding Item}" Style="{StaticResource IconSwitcherStyle}"/>
                            </Border>
                        </ContentControl>

                        <!-- Armor Slot -->
                        <ContentControl x:Name="ArmorSlot" 
                                       Style="{StaticResource EquipmentSlotStyle}"
                                       DataContext="{Binding ArmorSlot}"
                                       Tag="{Binding ArmorHint}"
                                       AllowDrop="True"
                                       Drop="EquipmentSlot_Drop"
                                       DragOver="EquipmentSlot_DragOver"
                                       PreviewMouseLeftButtonDown="EquipmentSlot_PreviewMouseLeftButtonDown"
                                       MouseEnter="EquipmentSlot_MouseEnter"
                                       MouseLeave="EquipmentSlot_MouseLeave">
                            <Border BorderBrush="{Binding BorderColor}" BorderThickness="2" CornerRadius="4">
                                <!-- Icon from DataTemplate -->
                                <ContentControl Content="{Binding Item}" Style="{StaticResource IconSwitcherStyle}"/>
                            </Border>
                        </ContentControl>

                        <!-- Accessory Slot -->
                        <ContentControl x:Name="AccessorySlot" 
                                       Style="{StaticResource EquipmentSlotStyle}"
                                       DataContext="{Binding AccessorySlot}"
                                       Tag="{Binding AccessoryHint}"
                                       AllowDrop="True"
                                       Drop="EquipmentSlot_Drop"
                                       DragOver="EquipmentSlot_DragOver"
                                       PreviewMouseLeftButtonDown="EquipmentSlot_PreviewMouseLeftButtonDown"
                                       MouseEnter="EquipmentSlot_MouseEnter"
                                       MouseLeave="EquipmentSlot_MouseLeave">
                            <Border BorderBrush="{Binding BorderColor}" BorderThickness="2" CornerRadius="4">
                                <!-- Icon from DataTemplate -->
                                <ContentControl Content="{Binding Item}" Style="{StaticResource IconSwitcherStyle}"/>
                            </Border>
                        </ContentControl>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Inventory Grid Section -->
            <Border Background="{DynamicResource Brush.TileBackground}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="{Binding InventoryTitle}" FontSize="14" Foreground="{DynamicResource Brush.SecondaryText}" FontWeight="Bold" Margin="0,0,0,12"/>

                    <!-- Items Grid using ItemsControl -->
                    <ItemsControl ItemsSource="{Binding InventoryItems}" x:Name="InventoryItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="70"/>
                                        <RowDefinition Height="70"/>
                                        <RowDefinition Height="70"/>
                                        <RowDefinition Height="70"/>
                                        <RowDefinition Height="70"/>
                                        <RowDefinition Height="70"/>
                                        <RowDefinition Height="70"/>
                                    </Grid.RowDefinitions>
                                </Grid>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style>
                                <Setter Property="Grid.Column" Value="{Binding Index, Converter={StaticResource IndexToColumnConverter}}"/>
                                <Setter Property="Grid.Row" Value="{Binding Index, Converter={StaticResource IndexToRowConverter}}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource InventorySlotStyle}" 
                                       BorderBrush="{Binding RarityBrush}"
                                       AllowDrop="True"
                                       Drop="InventorySlot_Drop"
                                       DragOver="InventorySlot_DragOver"
                                       PreviewMouseLeftButtonDown="InventorySlot_PreviewMouseLeftButtonDown"
                                       MouseEnter="InventorySlot_MouseEnter"
                                       MouseLeave="InventorySlot_MouseLeave">
                                    <Grid Background="Transparent">
                                        <!-- Display Icon from Icons.xaml DataTemplate based on Item.Id -->
                                        <ContentControl Content="{Binding Item}" Style="{StaticResource IconSwitcherStyle}" Margin="2"/>
                                        
                                        <!-- Stack Count Badge -->
                                        <TextBlock Text="{Binding Item.StackSize, StringFormat='0'}" 
                                                  Foreground="{DynamicResource Brush.Foreground}"
                                                  FontSize="12"
                                                  FontWeight="Bold"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Bottom"
                                                  Margin="4"
                                                  Background="#80000000"
                                                  Padding="2,0,2,0"
                                                  Visibility="{Binding Item.StackSize, Converter={StaticResource StackSizeToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Money Section -->
            <Border Background="{DynamicResource Brush.TileBackground}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="20">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="💰" FontSize="24" Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding MoneyBagTitle}" FontSize="12" Foreground="{DynamicResource Brush.SecondaryText}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding MoneyDisplay}" 
                                  FontSize="18" 
                                  Foreground="{DynamicResource Brush.Gold}" 
                                  FontWeight="Bold"
                                  FontFamily="Consolas"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Tooltip -->
        <Border x:Name="ItemTooltip" 
                Background="{DynamicResource Brush.TileBackground}" 
                BorderBrush="{DynamicResource Brush.Border}" 
                BorderThickness="1" 
                CornerRadius="6"
                Padding="12"
                Visibility="{Binding IsTooltipVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                MaxWidth="300"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,60,20,0">
            <StackPanel DataContext="{Binding CurrentTooltip}">
                <TextBlock Text="{Binding ItemName}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource Brush.Foreground}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding ItemType}" FontSize="11" Foreground="{DynamicResource Brush.SecondaryText}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding ItemRarity}" FontSize="11" FontWeight="Bold" Foreground="{Binding RarityColor}" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding ItemStats}" FontSize="10" Foreground="{DynamicResource Brush.SecondaryText}" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
