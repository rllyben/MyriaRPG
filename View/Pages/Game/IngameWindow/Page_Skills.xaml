<Page x:Class="MyriaRPG.View.Pages.Game.IngameWindow.Page_Skills"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:MyriaRPG.View.Pages.Game.IngameWindow"
      mc:Ignorable="d"
      Title="Skills">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Margin="12" Background="{DynamicResource Brush.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- header -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <!-- list -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding TblTitle}"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.Foreground}" />
                <TextBlock Text="  •  " Foreground="{DynamicResource Brush.SecondaryText}" FontSize="14" Margin="4,0"/>
                <TextBlock Text="{Binding HeaderText}"
                           FontSize="14" Foreground="{DynamicResource Brush.SecondaryText}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="{Binding TblCombineSkills}"
                        Command="{Binding OpenCombineCommand}"
                        Padding="12,4" Margin="0,0,8,0"/>
                <Button Content="{Binding TblManageSlots}"
                        Command="{Binding OpenSlotsCommand}"
                        Padding="12,4"/>
            </StackPanel>
        </Grid>

        <!-- Scrollable skills list -->
        <Border Grid.Row="2" Background="{DynamicResource Brush.TileBackground}" CornerRadius="8" Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Skills}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,4"
                                    Padding="8"
                                    Background="{DynamicResource Brush.Surface}"
                                    BorderBrush="{DynamicResource Brush.Border}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Name + class tag -->
                                    <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Foreground="{DynamicResource Brush.Foreground}" />
                                        <TextBlock Text="  •  " Foreground="{DynamicResource Brush.SecondaryText}"/>
                                        <TextBlock Text="{Binding ClassName}"
                                                   Foreground="{DynamicResource Brush.SecondaryText}"
                                                   FontSize="12" />
                                    </StackPanel>

                                    <!-- Short description -->
                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="{Binding ShortDescription}"
                                               Foreground="{DynamicResource Brush.SecondaryText}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,2"/>

                                    <!-- Tags row -->
                                    <StackPanel Grid.Row="2" Grid.Column="0"
                                                Orientation="Horizontal"
                                                Margin="0,2,0,0">
                                        <!-- Skill system tag: Rune / Fusion -->
                                        <Border Background="{DynamicResource Brush.Accent}"
                                                CornerRadius="4" Padding="4,1" Margin="0,0,4,0"
                                                Visibility="{Binding HasTag, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding Tag}" Foreground="{DynamicResource Brush.Foreground}" FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                        <!-- Type -->
                                        <Border Background="{DynamicResource Brush.TileBackground}" CornerRadius="4" Padding="4,1" Margin="0,0,4,0">
                                            <TextBlock Text="{Binding TypeText}" Foreground="{DynamicResource Brush.Foreground}" FontSize="11"/>
                                        </Border>
                                        <!-- Target -->
                                        <Border Background="{DynamicResource Brush.TileBackground}" CornerRadius="4" Padding="4,1" Margin="0,0,4,0">
                                            <TextBlock Text="{Binding TargetText}" Foreground="{DynamicResource Brush.Foreground}" FontSize="11"/>
                                        </Border>
                                        <!-- Healing -->
                                        <Border Background="{DynamicResource Brush.Success}" CornerRadius="4" Padding="4,1" Margin="0,0,4,0"
                                                Visibility="{Binding IsHealing, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Healing" Foreground="{DynamicResource Brush.Foreground}" FontSize="11"/>
                                        </Border>
                                        <!-- Level -->
                                        <Border Background="{DynamicResource Brush.TileBackground}" CornerRadius="4" Padding="4,1">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Min Lv. " Foreground="{DynamicResource Brush.SecondaryText}" FontSize="11"/>
                                                <TextBlock Text="{Binding MinLevel}" Foreground="{DynamicResource Brush.Foreground}" FontSize="11"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Mana / timing / details button -->
                                    <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="8,0,0,0">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="MP: " Foreground="{DynamicResource Brush.SecondaryText}" FontSize="12"/>
                                            <TextBlock Text="{Binding ManaCost}" Foreground="{DynamicResource Brush.Foreground}" FontSize="12"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding TimingText}"
                                                       Foreground="{DynamicResource Brush.SecondaryText}" FontSize="11"/>
                                        </StackPanel>
                                        <Button Content="Details"
                                                Command="{Binding DataContext.OpenDetailsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Margin="0,4,0,0"
                                                Padding="10,2"
                                                HorizontalAlignment="Right"
                                                FontSize="11"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
